              <label for="password">Password</label>
              <input id="password" type="password" name="password" required />
            </div>

            <div class="field">
              <label><input type="checkbox" name="is_super_admin" value="1" /> Super admin</label>
            </div>

            <div class="field">
              <label>Venue access</label>

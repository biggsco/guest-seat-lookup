});

router.post('/admin/users/new', async (req, res) => {
  const username = (req.body.username || '').trim();
  const password = String(req.body.password || '');
  const isSuperAdmin = req.body.is_super_admin === '1';
  const selectedVenues = parseSelectedVenues(req.body.allowed_venues);
  const allowedVenues = isSuperAdmin && selectedVenues.length === 0 ? VENUE_OPTIONS : selectedVenues;

  if (!username || !password) {
    return res.status(400).send('Username and password are required.');
  }

  if (password.length < 8) {
    return res.status(400).send('Password must be at least 8 characters.');
  }

  try {
    const existing = await getAdminByUsername(username);

    if (existing) {
      return res.status(400).send('That username already exists.');
    }

    const passwordHash = await bcrypt.hash(password, 12);

    await pool.query(
      `
      INSERT INTO admins (username, password_hash, is_super_admin, allowed_venues)
      VALUES ($1, $2, $3, $4)
      `,
      [username, passwordHash, isSuperAdmin, allowedVenues]
    );

    res.redirect('/admin/users');
  } catch (err) {
    res.status(500).send(escapeHtml(err.message));
  }
});

router.get('/admin/users/:id/promote', async (req, res) => {
  const id = Number(req.params.id);
  if (!id) return res.status(400).send('Invalid admin id.');

  try {
    await pool.query(
      `
      UPDATE admins
      SET is_super_admin = true
      WHERE id = $1
      `,
      [id]
    );

    res.redirect('/admin/users');
  } catch (err) {
    res.status(500).send(escapeHtml(err.message));
  }
});

router.get('/admin/users/:id/demote', async (req, res) => {
  const id = Number(req.params.id);
  if (!id) return res.status(400).send('Invalid admin id.');

  if (id === Number(req.session.adminUser.id)) {
    return res.status(400).send('You cannot demote yourself.');
  }

  try {
    await pool.query(
      `
      UPDATE admins
      SET is_super_admin = false
      WHERE id = $1
      `,
      [id]
    );

    await ensureAtLeastOneSuperAdmin();
    res.redirect('/admin/users');
  } catch (err) {
    res.status(500).send(escapeHtml(err.message));
  }
});

router.get('/admin/users/:id/password', async (req, res) => {
  const id = Number(req.params.id);
  if (!id) return res.status(400).send('Invalid admin id.');

  try {
    const result = await pool.query(
      `
      SELECT id, username
      FROM admins
      WHERE id = $1
      `,
      [id]
    );

    const user = result.rows[0];
    if (!user) return res.status(404).send('Admin not found.');

    res.send(
      renderLayout(
        'Reset Password',
        `
          ${adminNav(req, [{ href: '/admin/users', label: 'Back to Admin Users' }])}

          <div class="panel" style="max-width: 620px; margin: 0 auto;">
            <h1 style="margin-top: 0;">Reset Password</h1>
            <p class="muted">Set a new password for <strong>${escapeHtml(user.username)}</strong>.</p>

            <form method="POST" action="/admin/users/${id}/password">
              <div class="field">
                <label for="new_password">New Password</label>
                <input id="new_password" type="password" name="new_password" required />
              </div>
              <div class="actions">
                <button type="submit">Save Password</button>
                <a class="button secondary" href="/admin/users">Cancel</a>
              </div>
            </form>
          </div>
        `
      )
    );
  } catch (err) {
    res.status(500).send(escapeHtml(err.message));
  }
});

router.post('/admin/users/:id/password', async (req, res) => {
  const id = Number(req.params.id);
  const newPassword = String(req.body.new_password || '');

  if (!id) return res.status(400).send('Invalid admin id.');
  if (newPassword.length < 8) return res.status(400).send('Password must be at least 8 characters.');

  try {
    const passwordHash = await bcrypt.hash(newPassword, 12);

    await pool.query(
      `
      UPDATE admins
      SET password_hash = $2
      WHERE id = $1
      `,
      [id, passwordHash]
    );

    res.redirect('/admin/users');
  } catch (err) {
    res.status(500).send(escapeHtml(err.message));
  }
});

router.get('/admin/users/:id/venues', async (req, res) => {
  const id = Number(req.params.id);
  if (!id) return res.status(400).send('Invalid admin id.');

  try {
    const result = await pool.query(
      `
      SELECT id, username, allowed_venues
      FROM admins
      WHERE id = $1
      `,
      [id]
    );

    const user = result.rows[0];
    if (!user) return res.status(404).send('Admin not found.');

    const selectedVenues = Array.isArray(user.allowed_venues) ? user.allowed_venues : [];

    return res.send(
      renderLayout(
        'Update Venue Access',
        `
          ${adminNav(req, [{ href: '/admin/users', label: 'Back to Admin Users' }])}
          <div class="panel" style="max-width: 620px; margin: 0 auto;">
            <h1 style="margin-top: 0;">Update Venue Access</h1>
            <p class="muted">Set venue access for <strong>${escapeHtml(user.username)}</strong>.</p>

            <form method="POST" action="/admin/users/${id}/venues">
              <div class="field">
                ${VENUE_OPTIONS.map(venue => `
                  <label style="display:block; margin-top:6px;">
                    <input
                      type="checkbox"
                      name="allowed_venues"
                      value="${escapeHtml(venue)}"
                      ${selectedVenues.includes(venue) ? 'checked' : ''}
                    />
                    ${escapeHtml(venue)}
                  </label>
                `).join('')}
                <div class="muted small" style="margin-top: 6px;">Unchecked venues are hidden from this user.</div>
              </div>

              <div class="actions">
                <button type="submit">Save Venue Access</button>
                <a class="button secondary" href="/admin/users">Cancel</a>
              </div>
            </form>
          </div>
        `
      )
    );
  } catch (err) {
    return res.status(500).send(escapeHtml(err.message));
  }
});

router.post('/admin/users/:id/venues', async (req, res) => {
  const id = Number(req.params.id);
  if (!id) return res.status(400).send('Invalid admin id.');

  const allowedVenues = parseSelectedVenues(req.body.allowed_venues);

  try {
    await pool.query(
      `
      UPDATE admins
      SET allowed_venues = $2
      WHERE id = $1
      `,
      [id, allowedVenues]
    );

    if (id === Number(req.session.adminUser.id)) {
      req.session.adminUser.allowedVenues = allowedVenues;
    }

    return res.redirect('/admin/users');
  } catch (err) {
    return res.status(500).send(escapeHtml(err.message));
  }
});

router.get('/admin/users/:id/delete', async (req, res) => {
  const id = Number(req.params.id);
  if (!id) return res.status(400).send('Invalid admin id.');

  if (id === Number(req.session.adminUser.id)) {
    return res.status(400).send('You cannot delete yourself.');
  }

  try {
    await pool.query(
      `
      DELETE FROM admins
      WHERE id = $1
      `,
      [id]
    );

    await ensureAtLeastOneSuperAdmin();
    res.redirect('/admin/users');
  } catch (err) {
    res.status(500).send(escapeHtml(err.message));
  }
});

module.exports = router;
